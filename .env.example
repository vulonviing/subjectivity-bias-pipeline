# Copy to .env and fill in. Do NOT commit .env (it is gitignored).

# --- OpenAI (used for both LLM sentence annotation and VLM image annotation) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
# Optional: pin a snapshot for reproducibility (verified 2026-06-01)
OPENAI_MODEL_SNAPSHOT=gpt-5.4-mini-2026-03-17

# --- Crawler ---
USER_AGENT=media-bias-pipeline/0.1 (research; contact: your-email@example.com)
# Polite delay between requests to the same host, in seconds
CRAWL_DELAY_SEC=1.0

# --- Hugging Face (proxy classifier is public; token only needed for gated models) ---
HF_TOKEN=
